  const groups = [
    { title:"VALUE AREA (PRIOR DAY)", color:"#FFA726", fields:[
      {k:"vah",label:"VAH",c:"#66BB6A"},{k:"poc",label:"POC",c:"#FFA726"},{k:"val",label:"VAL",c:"#EF5350"}]},
    { title:"PRIOR DAY", color:"#4FC3F7", fields:[
      {k:"pdh",label:"PDH",c:"#4FC3F7"},{k:"pdc",label:"PDC",c:"#78909C"},{k:"pdl",label:"PDL",c:"#FF7043"}]},
    { title:"OVERNIGHT / ETH", color:"#CE93D8", fields:[
      {k:"globexH",label:"Globex High",c:"#CE93D8"},{k:"globexL",label:"Globex Low",c:"#BA68C8"},{k:"overnightMid",label:"ON Midpoint",c:"#7E57C2"}]},
    { title:"SESSION EXTREMES", color:"#81C784", fields:[
      {k:"asianH",label:"Asian High",c:"#4FC3F7"},{k:"asianL",label:"Asian Low",c:"#0288D1"},
      {k:"londonH",label:"London High",c:"#81C784"},{k:"londonL",label:"London Low",c:"#388E3C"}]},
  ];
  return (
    <div style={card}>
      <div style={cardHead()}><span style={lbl("#4FC3F7")}>KEY LEVELS — ES FUTURES</span></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:0}}>
        {groups.map((g,gi)=>(
          <div key={g.title} style={{padding:"14px 16px",borderRight:gi%2===0?"1px solid #1E2A32":"none",borderBottom:gi<2?"1px solid #1E2A32":"none"}}>
