function NewsPanel({ items, setItems }) {
  const [form, setForm] = useState({time:"",event:"",impact:"HIGH",expected:"",prior:"",notes:""});
  const upd = (k,v) => setForm(p=>({...p,[k]:v}));
  const add = () => { if (!form.event) return; setItems(p=>[...p,{...form,id:Date.now()}]); setForm({time:"",event:"",impact:"HIGH",expected:"",prior:"",notes:""}); };
  const NC = {HIGH:"#EF5350",MED:"#FFA726",LOW:"#78909C"};
  return (
    <div style={card}>
      <div style={cardHead()}><span style={lbl("#EF5350")}>ECONOMIC EVENTS & NEWS</span></div>
