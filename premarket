  const s = SESSIONS[session];
  const meta = SESSION_META[session];
  const schema = SESSION_FIELDS[session];
  const [showTips, setShowTips] = useState(false);

  return (
    <div>
      {/* Intent banner */}
      <div style={{background:`${s.color}0d`,border:`1px solid ${s.color}33`,borderRadius:6,padding:"12px 16px",marginBottom:16}}>
        <div style={{display:"flex",alignItems:"flex-start",justifyContent:"space-between",gap:12}}>
          <div style={{flex:1}}>
            <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}>
              <div style={{width:8,height:8,borderRadius:"50%",background:s.color,boxShadow:`0 0 6px ${s.color}`}}/>
              <span style={{fontFamily:mono,fontSize:10,color:s.color,letterSpacing:3,fontWeight:700}}>{session} SESSION — TRADE SETUP BRIEF</span>
              <span style={{fontFamily:mono,fontSize:9,color:"#37474F"}}>{s.hours}</span>
            </div>
            <div style={{fontFamily:mono,fontSize:10,color:"#546E7A",lineHeight:1.7}}>{meta.intent}</div>
          </div>
          <button onClick={()=>setShowTips(p=>!p)} style={{background:"transparent",border:`1px solid ${s.color}44`,color:s.color,fontFamily:mono,fontSize:9,padding:"4px 10px",cursor:"pointer",borderRadius:2,letterSpacing:1,flexShrink:0}}>
            {showTips?"HIDE TIPS":"TIPS"}
          </button>
        </div>
        {showTips && (
          <div style={{marginTop:10,paddingTop:10,borderTop:`1px solid ${s.color}22`}}>
            <div style={{...lbl("#37474F"),marginBottom:6}}>KNOWABLE AT {session} OPEN: {meta.knowable}</div>
            {meta.tips.map((t,i)=>(
              <div key={i} style={{display:"flex",gap:8,marginBottom:4}}>
                <span style={{color:s.color,fontSize:10}}>›</span>
                <span style={{fontFamily:mono,fontSize:10,color:"#455A64",lineHeight:1.5}}>{t}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <div style={card}>
        <div style={{padding:"14px 16px",display:"grid",gridTemplateColumns:"1fr 1fr",gap:24}}>
          {schema.map(g=>(
            <div key={g.title} style={{gridColumn:g.fields.some(f=>f.type==="ta")?"1 / -1":"auto"}}>
              <Section title={g.title} color={g.color}>
                {g.fields.map(f=>(
                  <Row key={f.k} label={f.label}>
                    {f.type==="sel" && <Sel value={data[f.k]} onChange={v=>upd(f.k,v)} opts={f.opts}/>}
                    {f.type==="num" && <NumInput value={data[f.k]} onChange={v=>upd(f.k,v)} step={f.step||"0.25"}/>}
                    {f.type==="ta"  && <textarea value={data[f.k]||""} onChange={e=>upd(f.k,e.target.value)} placeholder={f.placeholder||"Notes..."} style={taBase} rows={3}/>}
