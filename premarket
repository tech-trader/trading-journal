  LONDON: ["Assess completed Asian range size","Note Asian inventory into London","London open reaction vs Asian range","First 30m trend direction / structure","Asian extreme swept? (high prob setup)","VWAP relationship at London open","Key level broken or rejected?","NQ/YM alignment check"],
  RTH: ["Gap analysis — fill or continuation?","Price vs PDH/PDL/VAH/VAL confirmed","Full VWAP stack plotted and assessed","GEX flip level identified","IB high/low set (9:30–10:30)","Day type forming — trend or rotation?","News/event time logged","Prop risk params confirmed","Opening drive bias noted","London trend context applied"],
};

function Checklist({ checked, setChecked }) {
  const [active, setActive] = useState("RTH");
  const tog = (s,i) => setChecked(p=>({...p,[`${s}-${i}`]:!p[`${s}-${i}`]}));
  const prog = s => ({ d:CHECKLISTS[s].filter((_,i)=>checked[`${s}-${i}`]).length, t:CHECKLISTS[s].length });
  return (
    <div style={card}>
      <div style={cardHead()}><span style={lbl("#FFB74D")}>PRE-MARKET CHECKLIST</span></div>
      <div style={{display:"flex",borderBottom:"1px solid #1E2A32"}}>
        {Object.entries(SESSIONS).map(([k,s])=>{
          const {d,t}=prog(k); const ia=active===k;
          return (
            <button key={k} onClick={()=>setActive(k)} style={{flex:1,padding:"8px 12px",border:"none",cursor:"pointer",background:ia?s.dim:"transparent",borderBottom:ia?`2px solid ${s.color}`:"2px solid transparent"}}>
              <div style={{fontFamily:mono,fontSize:10,color:ia?s.color:"#37474F",letterSpacing:2}}>{k}</div>
              <div style={{fontFamily:mono,fontSize:9,color:d===t?"#66BB6A":"#37474F",marginTop:2}}>{d}/{t}</div>
            </button>
          );
        })}
      </div>
      <div style={{padding:16}}>
        {CHECKLISTS[active].map((item,i)=>{
          const done=checked[`${active}-${i}`];
          return (
            <div key={i} onClick={()=>tog(active,i)} style={{display:"flex",alignItems:"flex-start",gap:10,marginBottom:10,cursor:"pointer",opacity:done?0.4:1}}>
              <div style={{width:14,height:14,border:`1px solid ${done?SESSIONS[active].color:"#1E2A32"}`,borderRadius:2,flexShrink:0,marginTop:1,background:done?SESSIONS[active].color:"transparent",display:"flex",alignItems:"center",justifyContent:"center"}}>
                {done && <span style={{color:"#000",fontSize:9,fontWeight:900}}>✓</span>}
              </div>
              <span style={{fontFamily:mono,fontSize:11,color:done?"#263238":"#78909C",textDecoration:done?"line-through":"none",lineHeight:1.5}}>{item}</span>
            </div>
          );
        })}
        <button onClick={()=>CHECKLISTS[active].forEach((_,i)=>setChecked(p=>({...p,[`${active}-${i}`]:false})))}
          style={{background:"transparent",border:"1px solid #1E2A32",color:"#263238",fontFamily:mono,fontSize:9,padding:"4px 10px",cursor:"pointer",borderRadius:2,letterSpacing:1,marginTop:4}}>
          RESET SESSION
        </button>
      </div>
    </div>
  );
}

// ── AI Analysis ───────────────────────────────────────────────────────────────
function AIAnalysis({ session, levels, vwap, volProfile, options, macro, sessionData, newsItems, price, openPrice }) {
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);

  // Auto-calculate all price relationships to include in prompt
  const combinedLevels = { ...levels, ...vwap };
  const priceRels = price ? calcRelationships(price, combinedLevels) : [];
  const openRels  = openPrice ? calcRelationships(openPrice, combinedLevels) : [];

  const buildPrompt = () => {
    const s = SESSIONS[session];
    const meta = SESSION_META[session];
    const filled = obj => Object.entries(obj).filter(([,v])=>v).map(([k,v])=>`${k}: ${v}`).join("\n");

    return `You are an institutional ES futures analyst specialising in order flow and auction market theory. Generate a trading brief for finding trades DURING the ${session} session (${s.hours}).

SESSION INTENT: ${meta.intent}
KNOWABLE AT ${session} OPEN: ${meta.knowable}

Strategy guidance:
- ASIAN: Range plays off key levels, fades at overnight highs/lows, continuation of overnight direction. Targets 3-8pts. Tighter stops, lower volume.
- LONDON: Sweep-and-reverse off Asian extremes (high probability), VWAP reclaim/reject, directional breakout. Targets 5-15pts.
- RTH: Gap fill, IB extension, VWAP reclaim/reject, trend day breakouts. Targets 8-25pts.

## KEY LEVELS
${Object.entries(levels).filter(([,v])=>v).map(([k,v])=>`${k}: ${v}`).join("\n") || "Not provided"}

## VWAP LEVELS
${Object.entries(vwap).filter(([k,v])=>v && !k.endsWith("_note") && !k.endsWith("_rel")).map(([k,v])=>`${k}: ${v}`).join("\n") || "Not provided"}

## AUTO-CALCULATED PRICE RELATIONSHIPS
Current Price (${price||"not set"}):
${priceRels.map(r=>r.text).join("\n") || "Price not entered"}

Session Open Price (${openPrice||"not set"}):
${openRels.map(r=>r.text).join("\n") || "Open price not entered"}

## VOLUME PROFILE
Prior Week POC:${volProfile.pwPoc||"?"} VAH:${volProfile.pwVah||"?"} VAL:${volProfile.pwVal||"?"} Shape:${volProfile.pwShape||"?"}
Current Week POC:${volProfile.cwPoc||"?"} VAH:${volProfile.cwVah||"?"} VAL:${volProfile.cwVal||"?"} Shape:${volProfile.cwShape||"?"} Trend:${volProfile.cwTrend||"?"}
Prior Day Shape:${volProfile.pdShape||"?"} Day Type:${volProfile.pdDayType||"?"}
HVN1:${volProfile.hvn1||"?"} HVN2:${volProfile.hvn2||"?"} LVN1:${volProfile.lvn1||"?"} LVN2:${volProfile.lvn2||"?"}

## OPTIONS & DERIVATIVES
GEX Regime:${options.gexRegime||"?"} | GEX Flip:${options.gexFlip||"?"} | Call Wall:${options.callWall||"?"} | Put Wall:${options.putWall||"?"}
Dealer Positioning:${options.dealerPos||"?"}
VIX:${options.vix||"?"} | VIX Regime:${options.vixRegime||"?"} | VIX Trend:${options.vixTrend||"?"}
VVIX:${options.vvix||"?"} | IV Rank:${options.ivRank||"?"} | P/C Ratio:${options.putCallRatio||"?"} | 0DTE:${options.zeroDteFlow||"?"}
Term Structure:${options.termStructure||"?"}

## MACRO & SENTIMENT
ES Pre-mkt:${macro.esChange||"?"}% | NQ:${macro.nqAlign||"?"} | YM:${macro.ymAlign||"?"} | RTY:${macro.rtyAlign||"?"}
DXY:${macro.dxy||"?"} | 10Y Yield:${macro.tenYield||"?"} (${macro.yieldTrend||"?"})
Sector Rotation:${macro.sectorRotation||"?"} | Fear/Greed:${macro.fearGreed||"?"}
News Risk:${macro.newsRisk||"?"} | Event:${macro.newsEvent||"?"} at ${macro.newsTime||"?"}

## SESSION-SPECIFIC CONTEXT (${session})
${filled(sessionData)}

## SCHEDULED EVENTS
${newsItems.length ? newsItems.map(n=>`${n.time} ${n.event} [${n.impact}] exp:${n.expected||"?"} prev:${n.prior||"?"} ${n.notes||""}`).join("\n") : "None"}

---

Respond ONLY with valid JSON, no markdown, no preamble:
{
  "bias": "BULLISH|BEARISH|NEUTRAL|WAIT",
  "confidence": 1-10,
  "confidence_reason": "why this confidence level",
  "primary_narrative": "2-3 sentence core thesis",
  "key_context": ["point 1","point 2","point 3","point 4"],
  "strategies": [
    {
      "name": "strategy name",
      "type": "LONG|SHORT|FADE|BREAKOUT|RANGE",
      "setup": "specific entry condition",
      "entry_zone": "price level or condition",
      "target_1": "first target",
      "target_2": "second target",
      "stop": "stop condition",
      "invalidator": "what cancels this setup"
    }
  ],
  "levels_to_watch": [
    {"level": "price or description", "significance": "why it matters", "bias": "bull|bear|neutral"}
  ],
  "thesis_invalidators": ["condition 1","condition 2","condition 3"],
  "risk_notes": "risk factors, news sensitivity, vol regime implications",
  "market_regime": "brief market regime characterisation"
}`;
  };

  const analyze = async () => {
    setLoading(true); setError(null); setResult(null);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:2000, messages:[{role:"user",content:buildPrompt()}] })
      });
      const d = await res.json();
      if (d.error) throw new Error(d.error.message || JSON.stringify(d.error));
      const text = d.content?.map(c=>c.text||"").join("") || "";
      const parsed = JSON.parse(text.replace(/```json|```/g,"").trim());
      setResult(parsed);
    } catch(e) {
      setError(`Analysis failed: ${e.message}`);
    }
    setLoading(false);
  };

  const s = SESSIONS[session];
  const stratColors = {LONG:"#66BB6A",SHORT:"#EF5350",FADE:"#FFA726",BREAKOUT:"#4FC3F7",RANGE:"#CE93D8"};

  return (
    <div style={card}>
      <div style={{...cardHead(),borderLeft:`3px solid ${s.color}`}}>
        <span style={lbl(s.color)}>AI SESSION ANALYSIS — {session}</span>
        {result && (
          <div style={{display:"flex",alignItems:"center",gap:12}}>
            <span style={lbl()}>CONFIDENCE</span>
            <div style={{display:"flex",gap:2}}>
              {[...Array(10)].map((_,i)=><div key={i} style={{width:8,height:8,borderRadius:1,background:i<(result.confidence||0)?BC[result.bias]||"#546E7A":"#1E2A32"}}/>)}
            </div>
            <span style={{fontFamily:mono,fontSize:10,color:BC[result.bias]||"#546E7A"}}>{result.confidence}/10</span>
          </div>
        )}
      </div>
      <div style={{padding:"16px"}}>
        {!result && !loading && (
          <div style={{textAlign:"center",padding:"32px 0"}}>
            <div style={{fontFamily:mono,fontSize:11,color:"#37474F",marginBottom:16}}>Fill in market data and session context, then generate analysis.</div>
            <button onClick={analyze} style={{background:`${s.color}22`,border:`1px solid ${s.color}`,color:s.color,fontFamily:mono,fontSize:11,padding:"10px 28px",cursor:"pointer",borderRadius:3,letterSpacing:2}}>
              ▶ GENERATE {session} ANALYSIS
            </button>
          </div>
        )}
        {loading && (
          <div style={{textAlign:"center",padding:"32px 0"}}>
            <div style={{fontFamily:mono,fontSize:11,color:s.color,letterSpacing:3,animation:"fadeIn 1s infinite alternate"}}>ANALYZING MARKET CONDITIONS...</div>
            <style>{`@keyframes fadeIn{from{opacity:0.2}to{opacity:1}}`}</style>
          </div>
        )}
        {error && <div style={{fontFamily:mono,fontSize:11,color:"#EF5350",padding:"12px 0",whiteSpace:"pre-wrap"}}>{error}</div>}
        {result && (
          <div>
            <div style={{display:"flex",alignItems:"center",gap:16,marginBottom:20,padding:"14px 18px",background:`${BC[result.bias]}11`,border:`1px solid ${BC[result.bias]}44`,borderRadius:4}}>
              <div style={{fontFamily:"'Bebas Neue',sans-serif",fontSize:40,color:BC[result.bias],letterSpacing:4,lineHeight:1}}>{result.bias}</div>
              <div style={{flex:1}}>
                <div style={{fontFamily:mono,fontSize:11,color:"#B0BEC5",lineHeight:1.6}}>{result.primary_narrative}</div>
                <div style={{fontFamily:mono,fontSize:9,color:"#37474F",marginTop:6}}>{result.market_regime}</div>
              </div>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:16}}>
              <div>
                <div style={{...lbl("#4FC3F7"),marginBottom:10}}>KEY CONTEXT</div>
                {(result.key_context||[]).map((pt,i)=>(
                  <div key={i} style={{display:"flex",gap:8,marginBottom:8}}>
                    <div style={{width:16,height:16,borderRadius:2,background:`${s.color}22`,border:`1px solid ${s.color}44`,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,fontFamily:mono,fontSize:9,color:s.color}}>{i+1}</div>
                    <div style={{fontFamily:mono,fontSize:11,color:"#78909C",lineHeight:1.5}}>{pt}</div>
                  </div>
                ))}
              </div>
              <div>
                <div style={{...lbl("#EF5350"),marginBottom:10}}>THESIS INVALIDATORS</div>
                {(result.thesis_invalidators||[]).map((inv,i)=>(
                  <div key={i} style={{display:"flex",gap:8,marginBottom:8}}>
                    <div style={{color:"#EF5350",fontFamily:mono,fontSize:11,flexShrink:0}}>✕</div>
                    <div style={{fontFamily:mono,fontSize:11,color:"#78909C",lineHeight:1.5}}>{inv}</div>
                  </div>
                ))}
                <div style={{...lbl("#FFA726"),marginBottom:8,marginTop:14}}>RISK NOTES</div>
                <div style={{fontFamily:mono,fontSize:11,color:"#546E7A",lineHeight:1.6}}>{result.risk_notes}</div>
                {result.confidence_reason && (
                  <div style={{marginTop:10,padding:"8px 10px",background:"#07090C",border:"1px solid #1a2530",borderRadius:3}}>
                    <div style={{...lbl("#263238"),marginBottom:4}}>CONFIDENCE BASIS</div>
                    <div style={{fontFamily:mono,fontSize:10,color:"#455A64"}}>{result.confidence_reason}</div>
                  </div>
                )}
              </div>
            </div>
            <div style={{...lbl("#81C784"),marginBottom:10}}>POTENTIAL STRATEGIES</div>
            <div style={{display:"grid",gridTemplateColumns:`repeat(${Math.min((result.strategies||[]).length,3)},1fr)`,gap:12,marginBottom:16}}>
              {(result.strategies||[]).map((st,i)=>(
                <div key={i} style={{background:"#07090C",border:`1px solid ${stratColors[st.type]||"#1E2A32"}44`,borderRadius:4,padding:14}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
                    <div style={{padding:"2px 8px",background:`${stratColors[st.type]||"#546E7A"}22`,border:`1px solid ${stratColors[st.type]||"#546E7A"}66`,borderRadius:2,fontFamily:mono,fontSize:9,color:stratColors[st.type]||"#546E7A",letterSpacing:2}}>{st.type}</div>
                    <div style={{fontFamily:mono,fontSize:11,color:"#B0BEC5"}}>{st.name}</div>
                  </div>
                  {[{l:"SETUP",v:st.setup,c:"#78909C"},{l:"ENTRY",v:st.entry_zone,c:"#CFD8DC"},{l:"TARGET 1",v:st.target_1,c:"#66BB6A"},{l:"TARGET 2",v:st.target_2,c:"#4FC3F7"},{l:"STOP",v:st.stop,c:"#EF5350"},{l:"INVALIDATOR",v:st.invalidator,c:"#FFA726"}].map(r=>(
                    <div key={r.l} style={{display:"grid",gridTemplateColumns:"72px 1fr",gap:6,marginBottom:5}}>
                      <div style={{fontFamily:mono,fontSize:9,color:"#263238",letterSpacing:1}}>{r.l}</div>
                      <div style={{fontFamily:mono,fontSize:10,color:r.c,lineHeight:1.4}}>{r.v||"—"}</div>
                    </div>
                  ))}
                </div>
              ))}
            </div>
            <div style={{...lbl("#CE93D8"),marginBottom:10}}>LEVELS TO WATCH</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:16}}>
              {(result.levels_to_watch||[]).map((lv,i)=>(
                <div key={i} style={{padding:"8px 12px",background:"#07090C",border:`1px solid ${lv.bias==="bull"?"#66BB6A44":lv.bias==="bear"?"#EF535044":"#1a2530"}`,borderRadius:3,flex:"1 1 200px"}}>
                  <div style={{fontFamily:mono,fontSize:13,color:lv.bias==="bull"?"#66BB6A":lv.bias==="bear"?"#EF5350":"#78909C",marginBottom:4}}>{lv.level}</div>
                  <div style={{fontFamily:mono,fontSize:10,color:"#455A64"}}>{lv.significance}</div>
                </div>
              ))}
            </div>
            <div style={{textAlign:"right"}}>
              <button onClick={analyze} style={{background:"transparent",border:"1px solid #1E2A32",color:"#37474F",fontFamily:mono,fontSize:9,padding:"5px 12px",cursor:"pointer",borderRadius:2,letterSpacing:2}}>↺ RE-ANALYZE</button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// ── Main App ──────────────────────────────────────────────────────────────────
export default function App() {
  const [session,     setSession]     = useState("RTH");
  const [price,       setPrice]       = useState("");
  const [openPrice,   setOpenPrice]   = useState("");
  const [levels,      setLevels]      = useState({});
  const [vwap,        setVwap]        = useState({});
  const [volProfile,  setVolProfile]  = useState({});
  const [options,     setOptions]     = useState({});
  const [macro,       setMacro]       = useState({});
  const [sessionData, setSessionData] = useState({});
  const [newsItems,   setNewsItems]   = useState([]);
  const [checked,     setChecked]     = useState({});
  const [activeTab,   setActiveTab]   = useState("data");

  const resetDay = () => {
    if (!window.confirm("Reset all data for new trading day?")) return;
    setPrice(""); setOpenPrice(""); setLevels({}); setVwap({}); setVolProfile({});
    setOptions({}); setMacro({}); setSessionData({}); setNewsItems([]); setChecked({});
  };

  const totalChecks = Object.values(CHECKLISTS).flat().length;
  const doneChecks  = Object.values(checked).filter(Boolean).length;
  const s = SESSIONS[session];

  const combinedLevels = { ...levels, ...vwap };

  const TABS = [
    {k:"data",     label:"MARKET DATA"},
    {k:"session",  label:`${session} SESSION`},
    {k:"analysis", label:"AI ANALYSIS"},
    {k:"checklist",label:"CHECKLIST"},
  ];

  return (
    <div style={{minHeight:"100vh",background:"#060A0D",color:"#90A4AE",fontFamily:mono}}>
      {/* Header */}
      <div style={{borderBottom:"1px solid #1E2A32",padding:"14px 24px",display:"flex",alignItems:"center",justifyContent:"space-between",background:"#080C10",position:"sticky",top:0,zIndex:100}}>
        <div>
          <div style={{fontFamily:"'Bebas Neue',sans-serif",fontSize:26,color:"#E0E0E0",letterSpacing:5,lineHeight:1}}>PRE-MARKET ANALYSIS</div>
          <div style={{fontFamily:mono,fontSize:9,color:"#263238",letterSpacing:4,marginTop:3}}>ES FUTURES · {doneChecks}/{totalChecks} CHECKS · {session} ACTIVE</div>
        </div>
        <div style={{display:"flex",gap:6}}>
          {Object.entries(SESSIONS).map(([k,sv])=>(
            <button key={k} onClick={()=>setSession(k)} style={{padding:"8px 18px",border:`1px solid ${session===k?sv.color:"#1E2A32"}`,background:session===k?sv.dim:"transparent",color:session===k?sv.color:"#37474F",fontFamily:mono,fontSize:10,letterSpacing:3,cursor:"pointer",borderRadius:3,transition:"all 0.15s",position:"relative"}}>
              {session===k && <div style={{position:"absolute",top:0,left:0,right:0,height:2,background:sv.color,borderRadius:"3px 3px 0 0"}}/>}
              <div>{sv.label}</div>
              <div style={{fontSize:8,color:session===k?sv.color+"99":"#263238",marginTop:2}}>{sv.hours}</div>
            </button>
          ))}
        </div>
        <div style={{display:"flex",alignItems:"center",gap:16}}>
          <Clock/>
          <button onClick={resetDay} style={{background:"transparent",border:"1px solid #1E2A32",color:"#37474F",fontFamily:mono,fontSize:9,padding:"6px 12px",cursor:"pointer",borderRadius:2,letterSpacing:2}}>NEW DAY ↺</button>
        </div>
      </div>

      {/* Price inputs — always visible */}
      <div style={{background:"#080C10",borderBottom:"1px solid #1E2A32",padding:"10px 24px",display:"flex",alignItems:"center",gap:16}}>
        <div style={{fontFamily:mono,fontSize:9,color:"#37474F",letterSpacing:3,flexShrink:0}}>PRICES</div>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <div style={{fontFamily:mono,fontSize:9,color:"#546E7A",width:90}}>CURRENT</div>
          <input type="number" step="0.25" value={price} onChange={e=>setPrice(e.target.value)} placeholder="—"
            style={{...iBase,width:110,textAlign:"right",color:"#FFFFFF",fontSize:14,padding:"4px 10px"}}/>
        </div>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <div style={{fontFamily:mono,fontSize:9,color:"#546E7A",width:110}}>SESSION OPEN</div>
          <input type="number" step="0.25" value={openPrice} onChange={e=>setOpenPrice(e.target.value)} placeholder="—"
            style={{...iBase,width:110,textAlign:"right",color:s.color,fontSize:14,padding:"4px 10px"}}/>
        </div>
        {price && combinedLevels.vah && (
          <div style={{fontFamily:mono,fontSize:10,color:parseFloat(price)>parseFloat(combinedLevels.vah)?"#66BB6A":parseFloat(price)<parseFloat(combinedLevels.val)?"#EF5350":"#FFA726"}}>
            {parseFloat(price)>parseFloat(combinedLevels.vah)?"↑ ABOVE VAH":parseFloat(price)<parseFloat(combinedLevels.val)?"↓ BELOW VAL":"↔ INSIDE VA"}
            {combinedLevels.poc && ` | ${(parseFloat(price)-parseFloat(combinedLevels.poc))>0?"+":""}${(parseFloat(price)-parseFloat(combinedLevels.poc)).toFixed(2)} vs POC`}
          </div>
        )}
      </div>

      {/* Tabs */}
      <div style={{display:"flex",borderBottom:"1px solid #1E2A32",background:"#080C10",paddingLeft:24}}>
        {TABS.map(t=>(
          <button key={t.k} onClick={()=>setActiveTab(t.k)} style={{padding:"10px 18px",border:"none",cursor:"pointer",background:"transparent",borderBottom:activeTab===t.k?`2px solid ${s.color}`:"2px solid transparent",fontFamily:mono,fontSize:10,letterSpacing:2,color:activeTab===t.k?s.color:"#37474F"}}>
            {t.label}
          </button>
        ))}
      </div>

      <div style={{padding:"20px 24px"}}>
        {activeTab==="data" && (
          <div>
            <PriceSnapshot price={price} setPrice={setPrice} openPrice={openPrice} setOpenPrice={setOpenPrice} levels={{...levels,...vwap}} vwap={vwap}/>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
              <KeyLevels levels={levels} setLevels={setLevels}/>
              <VwapPanel data={vwap} setData={setVwap}/>
            </div>
            <VolumeProfilePanel data={volProfile} setData={setVolProfile}/>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
              <OptionsPanel data={options} setData={setOptions}/>
              <MacroPanel data={macro} setData={setMacro}/>
            </div>
            <NewsPanel items={newsItems} setItems={setNewsItems}/>
          </div>
        )}
        {activeTab==="session"   && <SessionPanel session={session} data={sessionData} setData={setSessionData}/>}
        {activeTab==="analysis"  && <AIAnalysis session={session} levels={levels} vwap={vwap} volProfile={volProfile} options={options} macro={macro} sessionData={sessionData} newsItems={newsItems} price={price} openPrice={openPrice}/>}
        {activeTab==="checklist" && <Checklist checked={checked} setChecked={setChecked}/>}
      </div>
    </div>
  );
}
