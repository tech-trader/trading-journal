          <div><div style={{...lbl(),marginBottom:4}}>TIME ET</div><input type="text" placeholder="09:30" value={form.time} onChange={e=>upd("time",e.target.value)} style={iBase}/></div>
          <div><div style={{...lbl(),marginBottom:4}}>EVENT</div><input type="text" placeholder="Event..." value={form.event} onChange={e=>upd("event",e.target.value)} style={iBase}/></div>
          <div><div style={{...lbl(),marginBottom:4}}>IMPACT</div><select value={form.impact} onChange={e=>upd("impact",e.target.value)} style={selBase}>{["HIGH","MED","LOW"].map(i=><option key={i}>{i}</option>)}</select></div>
          <div><div style={{...lbl(),marginBottom:4}}>EXPECTED</div><input type="text" value={form.expected} onChange={e=>upd("expected",e.target.value)} style={iBase}/></div>
          <div><div style={{...lbl(),marginBottom:4}}>PRIOR</div><input type="text" value={form.prior} onChange={e=>upd("prior",e.target.value)} style={iBase}/></div>
          <div><div style={{...lbl(),marginBottom:4}}>NOTES</div><input type="text" value={form.notes} onChange={e=>upd("notes",e.target.value)} style={iBase}/></div>
          <button onClick={add} style={{background:"#EF535022",border:"1px solid #EF5350",color:"#EF5350",cursor:"pointer",borderRadius:4,fontFamily:mono,fontSize:18,height:32,marginTop:"auto"}}>+</button>
        </div>
        {items.length===0 && <div style={{fontFamily:mono,fontSize:10,color:"#1E2A32",padding:"6px 0"}}>NO EVENTS LOGGED</div>}
        {items.map(it=>(
          <div key={it.id} style={{display:"grid",gridTemplateColumns:"80px 1fr 70px 100px 100px 1fr 32px",gap:6,marginBottom:6,alignItems:"center"}}>
            <div style={{fontFamily:mono,fontSize:11,color:"#546E7A",padding:"4px 8px",background:"#07090C",border:"1px solid #1a2530",borderRadius:3}}>{it.time}</div>
            <div style={{fontFamily:mono,fontSize:11,color:"#B0BEC5",padding:"4px 8px",background:"#07090C",border:"1px solid #1a2530",borderRadius:3}}>{it.event}</div>
            <div style={{fontFamily:mono,fontSize:11,color:NC[it.impact],padding:"4px 8px",background:"#07090C",border:`1px solid ${NC[it.impact]}44`,borderRadius:3,textAlign:"center"}}>{it.impact}</div>
            <div style={{fontFamily:mono,fontSize:11,color:"#546E7A",padding:"4px 8px",background:"#07090C",border:"1px solid #1a2530",borderRadius:3}}>{it.expected||"—"}</div>
            <div style={{fontFamily:mono,fontSize:11,color:"#546E7A",padding:"4px 8px",background:"#07090C",border:"1px solid #1a2530",borderRadius:3}}>{it.prior||"—"}</div>
