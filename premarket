// ── Price relationship calculator ─────────────────────────────────────────────
// Takes a price and named levels, returns human-readable context strings
function calcRelationships(price, levels) {
  if (!price || isNaN(parseFloat(price))) return null;
  const p = parseFloat(price);
  const n = (k) => levels[k] ? parseFloat(levels[k]) : null;
  const fmt = (v) => v !== null ? v.toFixed(2) : "?";
  const diff = (v) => v !== null ? `${p > v ? "+" : ""}${(p - v).toFixed(2)}` : null;
  const rel = (v, label) => {
    if (v === null) return null;
    const d = p - v;
    const abs = Math.abs(d);
    if (abs <= 0.5) return `AT ${label} (±0.5)`;
    return `${d > 0 ? "ABOVE" : "BELOW"} ${label} by ${abs.toFixed(2)}pts`;
  };

  const results = [];

  // Value Area
  const vah = n("vah"), poc = n("poc"), val = n("val");
  if (vah !== null && val !== null) {
    if (p > vah)       results.push({ key:"vs_VA",   text:`ABOVE VAH (${fmt(vah)}) — outside value, bullish`, color:"#66BB6A" });
    else if (p < val)  results.push({ key:"vs_VA",   text:`BELOW VAL (${fmt(val)}) — outside value, bearish`, color:"#EF5350" });
    else               results.push({ key:"vs_VA",   text:`INSIDE VALUE AREA — balanced, rotation expected`, color:"#FFA726" });
  }
  if (poc !== null) results.push({ key:"vs_POC", text:rel(poc, `POC ${fmt(poc)}`) + (poc ? ` | ${diff(poc)}pts` : ""), color:"#FFA726" });

  // Prior day
  const pdh = n("pdh"), pdc = n("pdc"), pdl = n("pdl");
  if (pdc !== null) results.push({ key:"vs_PDC", text:rel(pdc, `PDC ${fmt(pdc)}`) + ` | ${diff(pdc)}pts`, color:"#78909C" });
  if (pdh !== null) results.push({ key:"vs_PDH", text:rel(pdh, `PDH ${fmt(pdh)}`) + ` | ${diff(pdh)}pts`, color:"#4FC3F7" });
  if (pdl !== null) results.push({ key:"vs_PDL", text:rel(pdl, `PDL ${fmt(pdl)}`) + ` | ${diff(pdl)}pts`, color:"#FF7043" });

  // Globex
  const gH = n("globexH"), gL = n("globexL"), gMid = n("overnightMid");
  if (gH !== null && gL !== null) {
    const gmid = gMid !== null ? gMid : (gH + gL) / 2;
    results.push({ key:"vs_Globex", text:`Globex range ${fmt(gL)}–${fmt(gH)} | ${p > gmid ? "UPPER half" : "LOWER half"} of range | inventory: ${p > gmid ? "net long" : "net short"}`, color:"#CE93D8" });
  }

  // Asian
  const aH = n("asianH"), aL = n("asianL");
  if (aH !== null && aL !== null) {
    if (p > aH)      results.push({ key:"vs_Asian", text:`ABOVE Asian High (${fmt(aH)}) by ${(p-aH).toFixed(2)}pts — breakout`, color:"#4FC3F7" });
    else if (p < aL) results.push({ key:"vs_Asian", text:`BELOW Asian Low (${fmt(aL)}) by ${(aL-p).toFixed(2)}pts — breakdown`, color:"#0288D1" });
    else             results.push({ key:"vs_Asian", text:`INSIDE Asian range ${fmt(aL)}–${fmt(aH)} | ${p > (aH+aL)/2 ? "upper" : "lower"} half`, color:"#4FC3F7" });
  }

  // London
  const lH = n("londonH"), lL = n("londonL");
  if (lH !== null && lL !== null) {
    if (p > lH)      results.push({ key:"vs_London", text:`ABOVE London High (${fmt(lH)}) by ${(p-lH).toFixed(2)}pts`, color:"#81C784" });
    else if (p < lL) results.push({ key:"vs_London", text:`BELOW London Low (${fmt(lL)}) by ${(lL-p).toFixed(2)}pts`, color:"#388E3C" });
    else             results.push({ key:"vs_London", text:`INSIDE London range ${fmt(lL)}–${fmt(lH)}`, color:"#81C784" });
  }

  // VWAPs
  const vwapKeys = [
    { k:"sessionVwap", label:"Session VWAP" },
    { k:"pdVwapClose", label:"PD VWAP@Close" },
    { k:"weeklyVwap",  label:"Weekly VWAP" },
    { k:"monthlyVwap", label:"Monthly VWAP" },
    { k:"anchored1",   label:"Anchored VWAP 1" },
    { k:"anchored2",   label:"Anchored VWAP 2" },
  ];
  const vwapResults = vwapKeys
    .map(({ k, label }) => { const v = levels[k] ? parseFloat(levels[k]) : null; return v ? `${p > v ? "↑" : "↓"} ${p > v ? "above" : "below"} ${label}(${fmt(v)}) by ${Math.abs(p-v).toFixed(2)}` : null; })
    .filter(Boolean);
  if (vwapResults.length > 0) {
    const allAbove = vwapResults.every(r => r.startsWith("↑"));
    const allBelow = vwapResults.every(r => r.startsWith("↓"));
    results.push({ key:"vs_VWAPs", text:`VWAP stack: ${allAbove ? "BULLISH — price above all VWAPs" : allBelow ? "BEARISH — price below all VWAPs" : "MIXED — price between VWAPs"} | ${vwapResults.join(", ")}`, color:"#FFA726" });
  }

  // GEX flip
  const gfx = n("gexFlip");
  if (gfx !== null) results.push({ key:"vs_GEXFlip", text:`${p > gfx ? "ABOVE" : "BELOW"} GEX Flip (${fmt(gfx)}) by ${Math.abs(p-gfx).toFixed(2)}pts — ${p > gfx ? "long gamma / pinning regime" : "short gamma / vol amplification regime"}`, color:"#CE93D8" });

  // Call/Put walls
  const cw = n("callWall"), pw = n("putWall");
  if (cw !== null) results.push({ key:"vs_CallWall", text:`${Math.abs(p-cw).toFixed(2)}pts ${p < cw ? "below" : "above"} Call Wall (${fmt(cw)}) — ${p < cw ? "resistance above" : "above call wall, next resistance higher"}`, color:"#66BB6A" });
  if (pw !== null) results.push({ key:"vs_PutWall",  text:`${Math.abs(p-pw).toFixed(2)}pts ${p > pw ? "above" : "below"} Put Wall (${fmt(pw)}) — ${p > pw ? "support below" : "below put wall, next support lower"}`, color:"#EF5350" });

  return results;
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function NumInput({ value, onChange, color, placeholder="—", step="0.25" }) {
  return (
    <input type="number" step={step} value={value||""} placeholder={placeholder}
      onChange={e=>onChange(e.target.value)}
      style={{ ...iBase, color: color||"#CFD8DC", textAlign:"right" }}/>
  );
}
function Sel({ value, onChange, opts }) {
  return (
    <select value={value||""} onChange={e=>onChange(e.target.value)} style={selBase}>
      <option value="">—</option>
      {opts.map(o=><option key={o} value={o}>{o}</option>)}
    </select>
  );
}
function Row({ label, children, color }) {
  return (
    <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:8 }}>
      <div style={{ fontFamily:mono, fontSize:10, color: color||"#455A64", width:130, flexShrink:0 }}>{label}</div>
      <div style={{ flex:1 }}>{children}</div>
    </div>
  );
}
function Section({ title, color, children, right }) {
  return (
    <div style={{ marginBottom:20 }}>
      <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:10, paddingBottom:6, borderBottom:"1px solid #111820" }}>
        <span style={{ ...lbl(color||"#37474F") }}>{title}</span>
        {right && <span style={{ fontFamily:mono, fontSize:9, color:"#263238" }}>{right}</span>}
      </div>
      {children}
    </div>
  );
}

// ── Clock ─────────────────────────────────────────────────────────────────────
function Clock() {
  const [t, setT] = useState(new Date());
  useEffect(() => { const id = setInterval(()=>setT(new Date()),1000); return ()=>clearInterval(id); }, []);
  const et = t.toLocaleString("en-US",{timeZone:"America/New_York",hour:"2-digit",minute:"2-digit",second:"2-digit",hour12:false});
  const dt = t.toLocaleDateString("en-US",{timeZone:"America/New_York",weekday:"short",month:"short",day:"numeric"});
  return (
    <div style={{textAlign:"right"}}>
      <div style={{fontFamily:mono,fontSize:22,color:"#CFD8DC",letterSpacing:2}}>{et}</div>
      <div style={{fontFamily:mono,fontSize:9,color:"#37474F",letterSpacing:3,marginTop:2}}>{dt} ET</div>
    </div>
  );
}

// ── Price Snapshot (auto-calculated relationships) ────────────────────────────
function PriceSnapshot({ price, setPrice, openPrice, setOpenPrice, levels, vwap }) {
  const combinedLevels = { ...levels, ...vwap };
  const rels = price ? calcRelationships(price, combinedLevels) : null;
  const openRels = openPrice ? calcRelationships(openPrice, combinedLevels) : null;

  return (
    <div style={card}>
      <div style={cardHead()}>
        <span style={lbl("#FFFFFF")}>PRICE SNAPSHOT — AUTO CALCULATED</span>
        <span style={{fontFamily:mono,fontSize:9,color:"#263238"}}>ALL RELATIONSHIPS DERIVED FROM KEY LEVELS + VWAP INPUTS</span>
      </div>
      <div style={{padding:"14px 16px"}}>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:16}}>
          <div>
            <div style={{...lbl("#4FC3F7"),marginBottom:8}}>CURRENT PRICE</div>
            <NumInput value={price} onChange={setPrice} color="#FFFFFF" placeholder="Enter current price..."/>
            <div style={{fontFamily:mono,fontSize:9,color:"#263238",marginTop:4}}>↑ Input price above to calculate all relationships</div>
          </div>
          <div>
            <div style={{...lbl("#FFB74D"),marginBottom:8}}>SESSION OPEN PRICE</div>
            <NumInput value={openPrice} onChange={setOpenPrice} color="#FFB74D" placeholder="Enter session open..."/>
            <div style={{fontFamily:mono,fontSize:9,color:"#263238",marginTop:4}}>↑ Used for gap analysis and opening context</div>
          </div>
        </div>

        {rels && rels.length > 0 && (
          <div>
            <div style={{...lbl("#37474F"),marginBottom:10}}>CURRENT PRICE RELATIONSHIPS</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
              {rels.map(r=>(
                <div key={r.key} style={{padding:"6px 10px",background:"#07090C",border:`1px solid ${r.color}22`,borderRadius:3,borderLeft:`2px solid ${r.color}`}}>
                  <div style={{fontFamily:mono,fontSize:10,color:r.color,lineHeight:1.5}}>{r.text}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {openRels && openRels.length > 0 && (
          <div style={{marginTop:14}}>
            <div style={{...lbl("#37474F"),marginBottom:10}}>SESSION OPEN RELATIONSHIPS</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
              {openRels.map(r=>(
                <div key={r.key} style={{padding:"6px 10px",background:"#07090C",border:`1px solid ${r.color}11`,borderRadius:3,borderLeft:`2px solid ${r.color}88`}}>
                  <div style={{fontFamily:mono,fontSize:10,color:r.color+"99",lineHeight:1.5}}>{r.text}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        {!price && (
          <div style={{textAlign:"center",padding:"20px 0",fontFamily:mono,fontSize:10,color:"#1E2A32"}}>
            ENTER PRICES ABOVE TO SEE CALCULATED RELATIONSHIPS
          </div>
        )}
      </div>
    </div>
  );
}

// ── Key Levels ────────────────────────────────────────────────────────────────
